// Prisma schema — Agenda
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id               String    @id @default(cuid())
  userId           String?
  titulo           String
  descripcion      String?
  prioridad        String    @default("media") // "alta" | "media" | "baja"
  fechaVencimiento DateTime?
  recordatorioAt   DateTime?
  notificado       Boolean   @default(false)
  completada       Boolean   @default(false)
  hora             String? // "HH:MM" — hora opcional del día
  recurrencia      String    @default("ninguna") // "ninguna" | "diaria" | "intervalo" | "semanal"
  intervaloDias    Int? // cada X días (recurrencia = "intervalo")
  diasSemana       String? // csv 0-6, 0=domingo (recurrencia = "semanal")
  ultimaHechaDia   String? // "YYYY-MM-DD" de la última completación (recurrentes)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model EntertainmentItem {
  id         String   @id @default(cuid())
  userId     String?
  titulo     String
  categoria  String   // "pelis" | "series" | "musica" | "libros"
  completada Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RestaurantItem {
  id         String   @id @default(cuid())
  userId     String?
  titulo     String
  categoria  String   // "restaurantes" | "cafes" | "museos" | "ferias"
  completada Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  preferences        Json?
  accounts           Account[]
  sessions           Session[]
  tasks              Task[]
  entertainmentItems EntertainmentItem[]
  restaurantItems    RestaurantItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
